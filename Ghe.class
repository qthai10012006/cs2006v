package rapphim;

/**
 *
 * @author DELL
 */
public abstract class Ghe {
    protected String maGhe;
    protected TrangThaiGhe trangThai;
    protected int hang, cot;

    public Ghe(String maGhe, int hang, int cot) {
        this.maGhe = maGhe;
        this.hang = hang;
        this.cot = cot;
        this.trangThai = TrangThaiGhe.TRONG;
    }

    public abstract double tinhGia();

    public TrangThaiGhe getTrangThai() {
        return trangThai;
    }

    public void setTrangThai(TrangThaiGhe t) {
        this.trangThai = t;
    }

    public String getMaGhe() {
        return maGhe;
    }
}
